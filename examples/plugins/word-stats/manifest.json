{
  "id": "com.ciphertalk.example.word-stats",
  "name": "词频统计",
  "version": "1.0.0",
  "description": "统计会话近期消息的高频词，点击词语可复制",
  "apiVersion": 1,
  "author": { "name": "CipherTalk 官方示例", "email": "jin648862@gmail.com" },
  "permissions": ["sessions:read", "messages:read", "clipboard:write", "stt:use", "export:use"],
  "contributes": {
    "sidebarMenus": [
      { "id": "main", "label": "词频统计", "icon": "chart-bar", "view": "index" }
    ],
    "chatToolbarButtons": [
      { "id": "panel", "label": "会话分析", "icon": "sparkles", "view": "panel" }
    ],
    "views": {
      "index": { "entry": "index.html" },
      "panel": { "entry": "panel.html", "presentation": "drawer" }
    }
  }
}
