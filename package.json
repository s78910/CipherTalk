{
  "name": "ciphertalk",
  "version": "2026.724.0",
  "description": "密语 - 微信聊天记录查看工具",
  "author": "ILoveBingLu",
  "license": "CC-BY-NC-SA-4.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/clean-dist-electron.cjs && vite",
    "icon:mac": "bash scripts/build-macos-icon.sh",
    "native:macos": "bash native-dlls/build-macos.sh",
    "native:macos:check": "node scripts/check-macos-native.js",
    "native:image:check": "cargo check --manifest-path native/image-decrypt/Cargo.toml",
    "native:image:build": "cargo build --manifest-path native/image-decrypt/Cargo.toml --release",
    "native:image:check:current": "node scripts/check-image-native.cjs",
    "native:image:sync": "node scripts/sync-image-native.cjs",
    "native:image:build:sync": "npm run native:image:build && npm run native:image:sync",
    "build:prepare:mac": "node scripts/patch-dmg-builder.cjs",
    "build:prepare": "node scripts/update-readme-version.js && node scripts/prepare-release-announcement.js",
    "prebuild": "node scripts/update-readme-version.js && node scripts/prepare-release-announcement.js",
    "build": "node scripts/clean-dist-electron.cjs && NODE_OPTIONS=\"--max-old-space-size=4096\" tsc && vite build && electron-builder && node scripts/add-size-to-yml.js",
    "build:win": "npm run build:prepare && node scripts/clean-dist-electron.cjs && tsc && vite build && node scripts/run-electron-builder.cjs win && node scripts/generate-update-manifest.js win && node scripts/add-size-to-yml.js",
    "build:mac": "npm run build:prepare && npm run native:macos:check && npm run build:prepare:mac && node scripts/clean-dist-electron.cjs && tsc && vite build && node scripts/run-electron-builder.cjs mac && node scripts/generate-update-manifest.js mac && node scripts/add-size-to-yml.js",
    "build:ci": "node scripts/prepare-release-announcement.js && node scripts/clean-dist-electron.cjs && tsc && vite build && electron-builder --publish never && node scripts/generate-update-manifest.js && node scripts/add-size-to-yml.js",
    "build:mcp": "node scripts/clean-dist-electron.cjs && NODE_OPTIONS=\"--max-old-space-size=4096\" tsc && vite build",
    "build:force-update-manifest": "node scripts/generate-force-update-manifest.js",
    "build:release-context": "node scripts/generate-release-context.js",
    "build:release-body": "node scripts/generate-release-body.js",
    "build:release-announcement": "node scripts/prepare-release-announcement.js",
    "build:models-snapshot": "node scripts/fetch-models-dev-snapshot.cjs",
    "notify:telegram": "node scripts/send-telegram-release.js",
    "mcp": "node scripts/mcp-runner.js",
    "mcp:probe": "node scripts/mcp-probe.js",
    "test:mcp-lifecycle": "npm run build:mcp && node scripts/test-mcp-stdio-lifecycle.cjs",
    "cli": "npm --prefix CipherTalk-CLI run dev --",
    "cli:install": "npm --prefix CipherTalk-CLI install",
    "cli:typecheck": "npm --prefix CipherTalk-CLI run typecheck",
    "cli:test": "npm --prefix CipherTalk-CLI test -- --run",
    "cli:sync": "npm --prefix CipherTalk-CLI run sync:upstream",
    "test:agent-qa": "node scripts/test-agent-qa-independent.cjs",
    "test:agent-stream-sanitizer": "node --experimental-strip-types scripts/test-openai-compatible-stream-sanitizer.ts",
    "eval:retrieval": "node scripts/run-retrieval-evaluator.cjs",
    "preview": "vite preview",
    "electron:dev": "node scripts/clean-dist-electron.cjs && vite --mode electron",
    "electron:build": "npm run build",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.18",
    "@ai-sdk/google": "^4.0.23",
    "@ai-sdk/openai": "^4.0.20",
    "@ai-sdk/openai-compatible": "^3.0.14",
    "@ai-sdk/otel": "^1.0.36",
    "@ai-sdk/provider": "^4.0.3",
    "@ai-sdk/provider-utils": "^5.0.12",
    "@ai-sdk/react": "^4.0.39",
    "@gsap/react": "^2.1.2",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@internationalized/date": "^3.12.2",
    "@lottiefiles/dotlottie-react": "^0.19.10",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "adm-zip": "^0.5.16",
    "ai": "^7.0.36",
    "ansi-to-react": "^6.2.6",
    "better-sqlite3": "^12.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "echarts": "^6.1.0",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.40.0",
    "fzstd": "^0.1.1",
    "gsap": "^3.15.0",
    "https-proxy-agent": "^7.0.6",
    "jszip": "^3.10.1",
    "koffi": "^2.9.0",
    "nanoid": "^5.1.11",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "sharp": "^0.34.5",
    "sherpa-onnx-node": "^1.12.23",
    "shiki": "^4.2.0",
    "silk-wasm": "^3.7.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "undici": "^8.4.0",
    "use-stick-to-bottom": "^1.1.4",
    "virtua": "^0.49.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@gravity-ui/icons": "^2.20.0",
    "@lobehub/fluent-emoji": "^4.1.0",
    "@lobehub/icons": "^5.3.0",
    "@lobehub/ui": "^5.10.5",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^6.4.3",
    "dom-to-image-more": "^3.7.2",
    "dompurify": "^3.3.1",
    "electron": "^39.6.0",
    "electron-builder": "^25.1.8",
    "electron-store": "^10.0.0",
    "es-toolkit": "^1.46.1",
    "marked": "^17.0.1",
    "motion": "^12.40.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.1.1",
    "react-window": "^2.2.5",
    "sass": "^1.83.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wechat-emojis": "^1.0.2",
    "zustand": "^5.0.2"
  },
  "build": {
    "appId": "com.ciphertalk.app",
    "productName": "CipherTalk",
    "compression": "maximum",
    "npmRebuild": false,
    "afterPack": "scripts/clean-locales.js",
    "artifactName": "${productName}-${version}-Setup.${ext}",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "ILoveBingLu",
      "repo": "CipherTalk",
      "publishAutoUpdate": false
    },
    "win": {
      "icon": "public/icon.ico",
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker",
      "files": [
        "!node_modules/**/{darwin,mac}/**/*",
        "!node_modules/**/*.dylib",
        "!node_modules/sherpa-onnx-node/bin/!(win-x64)/**/*",
        "!node_modules/ffmpeg-static/bin/!(win32-x64)/**/*"
      ]
    },
    "mac": {
      "icon": "public/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/macos/entitlements.mac.plist",
      "entitlementsInherit": "resources/macos/entitlements.mac.plist"
    },
    "nsis": {
      "differentialPackage": false,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "unicode": true,
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052",
      "displayLanguageSelector": false,
      "include": "installer.nsh",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "perMachine": false,
      "allowElevation": true,
      "installerSidebar": null,
      "uninstallerSidebar": null
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*",
          "!whisper/**"
        ]
      },
      {
        "from": "electron/assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "public/tray-mac.png",
        "to": "tray-mac.png"
      },
      {
        "from": "public/miyuji",
        "to": "builtin-pets/miyuji"
      },
      {
        "from": ".tmp/release-announcement.json",
        "to": "release-announcement.json"
      },
      {
        "from": "skills/ct-mcp-copilot",
        "to": "builtin-skills/ct-mcp-copilot"
      },
      {
        "from": "skills/frontend-design",
        "to": "builtin-skills/frontend-design"
      }
    ],
    "extraFiles": [
      {
        "from": "scripts/ciphertalk-mcp.cmd",
        "to": "ciphertalk-mcp.cmd"
      },
      {
        "from": "scripts/ciphertalk-mcp-bootstrap.cjs",
        "to": "ciphertalk-mcp-bootstrap.cjs"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "skills/**/*",
      "!CipherTalk-CLI/**/*",
      "!resources/whisper/**/*",
      "!native-dlls/**/*",
      "!native/image-decrypt/**/*",
      "!tools/**/*",
      "!wcdb_api/**/*",
      "!node_modules/**/*.{txt,md,js.map,ts,html}",
      "!node_modules/**/*.map",
      "!node_modules/**/test/**/*",
      "!node_modules/**/docs/**/*",
      "!node_modules/**/examples/**/*",
      "!node_modules/**/{demo,demos}/**/*",
      "!node_modules/.vite/**/*",
      "!node_modules/onnxruntime-web/**/*",
      "!node_modules/**/{linux,android,ios,armhf,armv7l,ia32,wasm}/**/*",
      "!node_modules/**/*.so",
      "!node_modules/**/*.a",
      "!node_modules/**/*.obj",
      "!node_modules/**/*.pdb",
      "!node_modules/**/*.lib",
      "!node_modules/**/build/!(Release)/**/*",
      "node_modules/@opentelemetry/**/build/**/*",
      "node_modules/@fast-csv/**/*",
      "node_modules/{exceljs,archiver,archiver-utils,async,base64-js,big-integer,binary,bl,buffer,buffer-crc32,buffer-indexof-polyfill,buffers,chainsaw,compress-commons,concat-map,core-util-is,crc-32,crc32-stream,dayjs,duplexer2,end-of-stream,fast-csv,fs-constants,fs.realpath,fstream,glob,graceful-fs,ieee754,immediate,inflight,inherits,isarray,jszip,lazystream,lie,listenercount,lodash.defaults,lodash.difference,lodash.escaperegexp,lodash.flatten,lodash.groupby,lodash.isboolean,lodash.isequal,lodash.isfunction,lodash.isnil,lodash.isplainobject,lodash.isundefined,lodash.union,lodash.uniq,minimist,normalize-path,once,pako,path-is-absolute,process-nextick-args,readable-stream,readdir-glob,safe-buffer,saxes,setimmediate,string_decoder,tar-stream,tmp,traverse,unzipper,util-deprecate,uuid,wrappy,xmlchars,zip-stream}/**/*",
      "node_modules/@fast-csv/*/build/**/*",
      "node_modules/fast-csv/build/**/*",
      "!node_modules/**/deps/**/*",
      "node_modules/koffi/build/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/silk-wasm/**/*",
      "node_modules/sherpa-onnx-node/**/*",
      "node_modules/fzstd/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/koffi/**/*",
      "node_modules/zod/**/*",
      "node_modules/ai/**/*",
      "node_modules/@ai-sdk/**/*",
      "node_modules/undici/**/*",
      "node_modules/@opentelemetry/**/*",
      "node_modules/@vercel/oidc/**/*",
      "node_modules/json-schema/**/*",
      "node_modules/@standard-schema/spec/**/*",
      "node_modules/eventsource-parser/**/*",
      "node_modules/@fast-csv/**/*",
      "node_modules/{exceljs,archiver,archiver-utils,async,base64-js,big-integer,binary,bl,buffer,buffer-crc32,buffer-indexof-polyfill,buffers,chainsaw,compress-commons,concat-map,core-util-is,crc-32,crc32-stream,dayjs,duplexer2,end-of-stream,fast-csv,fs-constants,fs.realpath,fstream,glob,graceful-fs,ieee754,immediate,inflight,inherits,isarray,jszip,lazystream,lie,listenercount,lodash.defaults,lodash.difference,lodash.escaperegexp,lodash.flatten,lodash.groupby,lodash.isboolean,lodash.isequal,lodash.isfunction,lodash.isnil,lodash.isplainobject,lodash.isundefined,lodash.union,lodash.uniq,minimist,normalize-path,once,pako,path-is-absolute,process-nextick-args,readable-stream,readdir-glob,safe-buffer,saxes,setimmediate,string_decoder,tar-stream,tmp,traverse,unzipper,util-deprecate,uuid,wrappy,xmlchars,zip-stream}/**/*",
      "dist-electron/**/*",
      "resources/wedecrypt/*.node",
      "resources/wedecrypt/**/*.node",
      "resources/**/*"
    ]
  }
}
